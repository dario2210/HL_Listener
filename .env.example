POSTGRES_DB=whale_listener
POSTGRES_USER=listener
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://listener:change-me@db:5432/whale_listener

HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

TRACKED_COINS=BTC,ETH
TRACKED_KEYWORDS=
MIN_NOTIONAL_USD=100000

WS_HEARTBEAT_SECONDS=20
RECONNECT_INITIAL_DELAY_SECONDS=2
RECONNECT_MAX_DELAY_SECONDS=30
DATABASE_CONNECT_RETRY_SECONDS=5

LOG_LEVEL=INFO
PRINT_DISCOVERED_MARKETS=false
